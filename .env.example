# Configuración de GitHub para almacenar noticias
GITHUB_TOKEN=tu_token_personal_de_github_aqui

# El token debe tener permisos:
# - repo (acceso completo a repositorios privados)
# - gist (opcional)

# Cómo generar tu token:
# 1. Ve a https://github.com/settings/tokens
# 2. Click en "Generate new token"
# 3. Dale nombre: "TequenoBot"
# 4. Selecciona scope: repo
# 5. Copia el token (solo sale una vez)
# 6. Pégalo aquí
